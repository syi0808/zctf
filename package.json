{
  "name": "zctf-poc",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/runtime",
    "packages/config",
    "bench"
  ],
  "scripts": {
    "generate": "node scripts/generate.js schemas/zctf.schema.json packages/bench/fixtures/bench-report.schema.json",
    "build:napi": "napi build --platform --release --manifest-path crates/zctf-napi/Cargo.toml --output-dir native",
    "build:ffi": "cargo build --release -p zctf-bench-ffi",
    "build:wasm": "cargo build --release -p zctf-bench-wasm --target wasm32-unknown-unknown",
    "build": "npm run build:napi && npm run build:ffi && npm run build:wasm",
    "test": "cargo test --workspace && node --test packages/*/test/*.test.js",
    "bench": "node --expose-gc packages/bench/src/napi.bench.js",
    "product:build": "pnpm --filter zctf-product-benchmark build",
    "product:test": "pnpm --filter zctf-product-benchmark test",
    "product:bench": "pnpm --filter zctf-product-benchmark bench:quick",
    "bench:quick": "node --expose-gc packages/bench/src/napi.bench.js --quick --output=/tmp/zctf-napi-quick.json",
    "bench:string-decode": "node --expose-gc scripts/bench-string-decode.js",
    "bench:bun": "bun packages/bench/src/bun-ffi.bench.js",
    "bench:wasm": "node packages/bench/src/wasm.bench.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "packageManager": "pnpm@11.5.2"
}
